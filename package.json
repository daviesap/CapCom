{
  "name": "capcom",
  "private": true,
  "version": "0.0.12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "functions:lint": "npm --prefix functions run lint",
    "emulate:functions": "NO_UPDATE_NOTIFIER=1 firebase emulators:start --project capcom-d2cc0 --only functions",
    "emulate": "NO_UPDATE_NOTIFIER=1 firebase emulators:start --project capcom-d2cc0 --only functions,firestore,storage",
    "deploy": "npm run build && NO_UPDATE_NOTIFIER=1 firebase deploy --project capcom-d2cc0",
    "deploy:hosting": "npm run build && NO_UPDATE_NOTIFIER=1 firebase deploy --project capcom-d2cc0 --only hosting",
    "deploy:functions": "NO_UPDATE_NOTIFIER=1 firebase deploy --project capcom-d2cc0 --only functions",
    "deploy:rules": "NO_UPDATE_NOTIFIER=1 firebase deploy --project capcom-d2cc0 --only firestore:rules,storage"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "^4.4.1",
    "firebase": "^11.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.3",
    "sonner": "^2.0.7",
    "vite": "^6.3.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "eslint": "^9.26.0",
    "eslint-plugin-react": "^7.37.5",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.20.0",
    "globals": "^16.1.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
